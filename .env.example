# Public site URL (no trailing slash). Used for canonical URLs, sitemap, JSON-LD, OG tags.
NEXT_PUBLIC_SITE_URL=https://hadadelectric.co.il

# Base44 app ID (the app id segment in the Base44 API URL).
NEXT_PUBLIC_BASE44_APP_ID=697dbf6bdde569f5ea050a4e

# Base44 API base URL. Defaults to https://base44.app/api/apps/<NEXT_PUBLIC_BASE44_APP_ID>
# Only override if Base44 gives you a different base URL.
BASE44_APP_BASE_URL=https://base44.app/api/apps/697dbf6bdde569f5ea050a4e

# Optional: only needed if Base44 adds authentication to the public catalog
# endpoint in the future. The confirmed getProductCatalog endpoint currently
# requires no auth token. Never expose this value to the client.
BASE44_API_TOKEN=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GA_ID=

# Google Tag Manager container ID (e.g. GTM-XXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GTM_ID=

# --- Admin BI dashboard (/admin) ---
# Password for the /admin business dashboard. Server-only (never expose to the
# client). Leave empty to keep the dashboard locked.
ADMIN_PASSWORD=

# Analytics storage: Vercel KV / Upstash Redis REST credentials. Connecting a
# Vercel KV (or Upstash) store to the project sets these automatically. Without
# them, tracking safely no-ops and the dashboard shows zeros — the site is
# unaffected. Native Upstash env names (UPSTASH_REDIS_REST_URL / _TOKEN) also work.
KV_REST_API_URL=
KV_REST_API_TOKEN=
